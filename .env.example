# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transactions?schema=public"
DATABASE_STRATEGY=pool

# Nivel de log (trace, debug, info, warn, error). Em "debug" mostra cada
# chamada de leitura/atualizacao do LoggingRepositoryDecorator.
LOG_LEVEL=info

# Id do item de estoque usado pela demo (index.js) e pelo seed (prisma/seed.js).
STOCK_ITEM_ID="f92ef45b-a729-4938-b580-03d939a80301"

# Estoque inicial usado pelo seed - util para simular cenarios (ex: amount=0
# para testar estoque insuficiente, amount=1 para forcar conflitos de versao).
SEED_STOCK_AMOUNT=10
SEED_STOCK_VERSION=0